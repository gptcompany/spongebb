{
  "domain": "finance",
  "scan_path": "src",
  "commands": {
    "python": "uv run python",
    "pyright": "uv run pyright",
    "ruff": "uv run ruff",
    "pytest": "uv run pytest",
    "bandit": "uv run bandit"
  },
  "anti_patterns": [
    "hardcoded_api_keys",
    "missing_error_handling",
    "blocking_io_in_async",
    "raw_sql_injection"
  ],
  "research_keywords": {
    "trigger": [
      "FRED API",
      "ECB SDW",
      "BIS SDMX",
      "central bank",
      "liquidity index",
      "Hayes formula"
    ],
    "skip": [
      "basic_python",
      "simple_fix",
      "plotly_chart"
    ]
  },
  "timeouts": {
    "code_quality": 60,
    "type_safety": 300,
    "security": 300,
    "coverage": 600,
    "default": 120
  },
  "dimensions": {
    "code_quality": {"enabled": true, "tier": 1},
    "type_safety": {"enabled": true, "tier": 2},
    "security": {"enabled": true, "tier": 1},
    "coverage": {"enabled": true, "tier": 1}
  },
  "quality_gates": {
    "min_test_coverage": 80,
    "max_complexity": 10,
    "require_docstrings": true
  }
}
