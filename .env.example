# Global Liquidity Monitor - Environment Variables
# Copy to .env and fill in values for local development
# For secrets (API keys), use dotenvx encryption instead

# =============================================================================
# API Server Configuration
# =============================================================================

# Port for the API server (default: 8000)
LIQUIDITY_API_PORT=8000

# =============================================================================
# API Keys (NEVER commit real values - use dotenvx encryption)
# =============================================================================

# FRED API key - get from https://fred.stlouisfed.org/docs/api/api_key.html
# For OpenBB (reads from env var with OPENBB_ prefix):
# OPENBB_FRED_API_KEY=your_fred_api_key_here
# Legacy:
# LIQUIDITY_FRED_API_KEY=your_fred_api_key_here
#
# NOTE: Use dotenvx for encryption:
#   1. Copy .env.example to .env
#   2. Fill in real values
#   3. Run: dotenvx encrypt
#   4. Share .env (encrypted), keep .env.keys private
#   5. Run commands with: dotenvx run -- <command>

# =============================================================================
# QuestDB Configuration
# =============================================================================

# QuestDB host and ports
# For local dev: localhost
# For Docker isolated: liquidity-questdb
LIQUIDITY_QUESTDB_HOST=localhost
LIQUIDITY_QUESTDB_PORT=9009
LIQUIDITY_QUESTDB_HTTP_PORT=9000

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection URL
LIQUIDITY_REDIS_URL=redis://localhost:6379

# =============================================================================
# Prometheus Metrics
# =============================================================================

# Port for Prometheus metrics exposition
LIQUIDITY_PROMETHEUS_PORT=8000

# =============================================================================
# Circuit Breaker Settings
# =============================================================================

# Number of failures before circuit opens
LIQUIDITY_CB_THRESHOLD=5
# Seconds before trying half-open state
LIQUIDITY_CB_TTL=60

# =============================================================================
# Retry Settings
# =============================================================================

# Maximum retry attempts
LIQUIDITY_RETRY_MAX_ATTEMPTS=5
# Exponential backoff multiplier
LIQUIDITY_RETRY_MULTIPLIER=1.0
# Minimum wait between retries (seconds)
LIQUIDITY_RETRY_MIN_WAIT=1
# Maximum wait between retries (seconds)
LIQUIDITY_RETRY_MAX_WAIT=60

# =============================================================================
# Logging
# =============================================================================

LIQUIDITY_LOG_LEVEL=INFO

# =============================================================================
# Alerting / Notifications
# =============================================================================

# App-level Discord alerting consumed by liquidity.alerts.*
LIQUIDITY_DISCORD_WEBHOOK_URL=

# Infra / workflow notifications used by self-hosted deploy automation
DISCORD_WEBHOOK_SPONGEBB=
