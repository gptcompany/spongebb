# Global Liquidity Monitor - Docker Ignore
# Excludes files not needed in container to reduce build context

# =============================================================================
# Version Control
# =============================================================================
.git/
.gitignore
.gitattributes

# =============================================================================
# Project Metadata (not needed in container)
# =============================================================================
.planning/
.claude/
.claude-flow/
.github/
*.md
!README.md
catalog-info.yaml

# =============================================================================
# Development Tools
# =============================================================================
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# =============================================================================
# Testing
# =============================================================================
tests/
.coverage
htmlcov/
coverage.xml
*.cover

# =============================================================================
# IDE / Editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Environment / Secrets
# =============================================================================
.env
.env.*
!.env.example
*.keys

# =============================================================================
# Build Artifacts
# =============================================================================
dist/
build/
*.egg-info/

# =============================================================================
# Misc
# =============================================================================
*.log
*.tmp
.DS_Store
Thumbs.db
scripts/
